<AnchorPane fx:id="apContenedorCentro" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" stylesheets="@Estilos/Estilos_Interfaz.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="interfaz.mobimedline_sistema.ConsultarProductoController">
   <children>
      <Label fx:id="lblAgregarUsuarioTitulo" layoutX="33.0" layoutY="14.0" maxWidth="200.0" minWidth="200.0" prefWidth="200.0" styleClass="Texto-remarcado-azul-titulo" text="CATÁLOGO" textAlignment="CENTER" AnchorPane.leftAnchor="33.0" AnchorPane.topAnchor="14.0" />
      <VBox layoutY="38.0" prefHeight="54.0" prefWidth="399.0" spacing="10.0" AnchorPane.leftAnchor="33.0" AnchorPane.rightAnchor="17.0" AnchorPane.topAnchor="42.0">
         <children>
            <HBox alignment="CENTER" spacing="10">
               <children>
                  <Label minHeight="-Infinity" minWidth="-Infinity" styleClass="Texto" text="Buscar:" />
                  <TextField fx:id="txtBuscar" promptText="Nombre producto" styleClass="Campo-Texto-redondo" HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnBuscar" onAction="#buscar" styleClass="Boton-Azul" text="Buscar">
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </Button>
                  <Button fx:id="btnLimpiar" onAction="#limpiar" styleClass="Boton-Rojo" text="Limpiar">
