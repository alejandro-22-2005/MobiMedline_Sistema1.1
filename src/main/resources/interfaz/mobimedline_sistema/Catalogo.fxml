                  <TableColumn fx:id="colNombre" prefWidth="114.0" text="Nombre" />
                  <TableColumn fx:id="colUnidad" prefWidth="93.0" text="Cantidad" />
               </columns>
            </TableView>
         </children>
      </HBox>
      <HBox alignment="CENTER" layoutX="28.0" layoutY="360.0" prefHeight="38.0" prefWidth="383.0" spacing="10.0" AnchorPane.bottomAnchor="14.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="20.0" />
