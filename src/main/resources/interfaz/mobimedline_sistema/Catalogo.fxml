                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </Button>
               </children>
            </HBox>
            <HBox alignment="CENTER" spacing="10.0" />
         </children>
      </VBox>
      <HBox layoutX="35.0" layoutY="163.0" spacing="25" AnchorPane.bottomAnchor="64.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="118.0">
         <children>
            <VBox prefHeight="258.0" prefWidth="269.0" spacing="10" style="-fx-background-color: #d9d9d9; -fx-padding: 15;">
               <children>
                  <Label minWidth="72.0" prefHeight="18.0" prefWidth="72.0" styleClass="Texto-remarcado-azul-titulo" text="Productos" />
                  <TableView fx:id="tvProductos" prefHeight="200.0" prefWidth="179.0" VBox.vgrow="ALWAYS">
                     <columns>
