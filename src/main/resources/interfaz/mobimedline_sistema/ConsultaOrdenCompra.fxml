<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:id="apContenedorCentro" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" stylesheets="@Estilos/Estilos_Interfaz.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="interfaz.mobimedline_sistema.ConsultaOrdenCompraController">
   <children>
      <Label fx:id="lblAgregarUsuarioTitulo" layoutX="33.0" layoutY="14.0" maxWidth="200.0" minWidth="200.0" prefWidth="200.0" styleClass="Texto-remarcado-azul-titulo" text="CONSULTAR ODC" textAlignment="CENTER" AnchorPane.leftAnchor="33.0" AnchorPane.topAnchor="14.0" />
      <HBox alignment="CENTER_RIGHT" layoutX="33.0" layoutY="42.0" prefHeight="77.0" prefWidth="375.0" spacing="10.0" style="-fx-background-color: #f0f0f0;" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="42.0">
         <children>
            <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="Texto" text="ID ODC" />
                  <TextField fx:id="tfIdOrden" maxWidth="1.7976931348623157E308" styleClass="Campo-Texto-redondo" />
               </children>
            </VBox>
            <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="Texto" text="EMISIÓN" />
                  <DatePicker fx:id="dpFechaEmision" maxWidth="1.7976931348623157E308" styleClass="date-picker" />
               </children>
            </VBox>
            <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="Texto" text="ESTADO" />
                  <ComboBox fx:id="cbEstado" maxWidth="1.7976931348623157E308" prefWidth="150.0" styleClass="combo-box" />
               </children>
            </VBox>
            <Button fx:id="btnBuscar" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#handleBuscar" styleClass="Boton-Azul" text="Buscar" />
            <Button fx:id="btnLimpiar" mnemonicParsing="false" onAction="#handleLimpiar" styleClass="Boton-Rojo" text="Limpiar" />
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </HBox>
      <VBox layoutX="36.0" layoutY="118.0" prefHeight="238.0" prefWidth="368.0" AnchorPane.bottomAnchor="64.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="118.0">
         <children>
            <Label styleClass="Texto-remarcado-azul" text="LISTA DE ÓRDENES" />
            <TableView fx:id="tlvLista" prefHeight="200.0" prefWidth="200.0" styleClass="list-view" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="tlcIdOrden" prefWidth="66.0" text="ID ODC" />
                  <TableColumn fx:id="tlcResponsable" prefWidth="111.0" text="Responsable" />
                  <TableColumn fx:id="tlcEmision" prefWidth="109.0" text="Fecha Emision" />
                  <TableColumn fx:id="tlcEstatus" prefWidth="81.0" text="Estatus" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>
      <HBox alignment="CENTER" layoutX="28.0" layoutY="360.0" prefHeight="38.0" prefWidth="383.0" AnchorPane.bottomAnchor="14.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="20.0">
         <children>
            <Button fx:id="btnVerdetalle" mnemonicParsing="false" onAction="#handleVerDetalles" styleClass="Boton-Azul-Grande" text="VER DETALLES" />
         </children>
      </HBox>
   </children>
</AnchorPane>
