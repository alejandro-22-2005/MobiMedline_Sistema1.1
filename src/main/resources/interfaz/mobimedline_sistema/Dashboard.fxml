<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="20" style="-fx-padding: 20; -fx-background-color: white;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="interfaz.mobimedline_sistema.DashboardController">
   <children>
      <HBox alignment="CENTER" spacing="20">
         <children>
            <VBox style="-fx-background-color: #0d273e; -fx-padding: 15; -fx-background-radius: 10;">
               <children>
                  <Label style="-fx-text-fill: white;" text="ODC pendientes" />
                  <Label fx:id="lblPendientes" alignment="CENTER" prefHeight="30.0" prefWidth="86.0" style="-fx-text-fill: white; -fx-font-size: 20px;" text="0" />
               </children>
            </VBox>
            <VBox style="-fx-background-color: #0d273e; -fx-padding: 15; -fx-background-radius: 10;">
               <children>
                  <Label style="-fx-text-fill: white;" text="ODC procesadas" />
                  <Label fx:id="lblProcesadas" alignment="CENTER" prefHeight="30.0" prefWidth="89.0" style="-fx-text-fill: white; -fx-font-size: 20px;" text="0" />
               </children>
            </VBox>
            <VBox style="-fx-background-color: #0d273e; -fx-padding: 15; -fx-background-radius: 10;">
               <children>
                  <Label style="-fx-text-fill: white;" text="ODC especiales" />
                  <Label fx:id="lblEspeciales" alignment="CENTER" prefHeight="30.0" prefWidth="76.0" style="-fx-text-fill: white; -fx-font-size: 20px;" text="0" />
               </children>
            </VBox>
         </children>
      </HBox>
      <Label style="-fx-font-weight: bold;" text="ÚLTIMAS ÓRDENES CREADAS" />
      <TableView fx:id="tablaOrdenes" stylesheets="@Estilos/Estilos_Interfaz.css" VBox.vgrow="NEVER">
         <columns>
            <TableColumn fx:id="colId" text="ID ORDEN" />
            <TableColumn fx:id="colFecha" text="FECHA" />
            <TableColumn fx:id="colUsuario" text="CREADA POR" />
            <TableColumn fx:id="colEstado" text="ESTADO" />
         </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </children>
</VBox>
