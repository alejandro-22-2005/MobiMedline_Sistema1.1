<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane minHeight="423.0" minWidth="430.0" prefHeight="423.0" prefWidth="430.0" stylesheets="@Estilos/Estilos_Interfaz.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="interfaz.mobimedline_sistema.NuevaODCController">
   <top>
      <VBox prefHeight="101.0" prefWidth="539.0" BorderPane.alignment="CENTER_LEFT">
         <children>
            <Label fx:id="lblGenerar" prefHeight="112.0" prefWidth="1088.0" styleClass="Texto-remarcado-azul-titulo" text="NUEVA ODC">
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </Label>
            <HBox prefHeight="45.0" prefWidth="491.0" spacing="10.0">
               <children>
                  <Label fx:id="lblID" minWidth="19.0" prefHeight="22.0" prefWidth="24.0" styleClass="Texto-remarcado-azul" text="SKU">
                     <HBox.margin>
                        <Insets />
                     </HBox.margin>
                     <padding>
                        <Insets top="5.0" />
                     </padding>
                  </Label>
                  <TextField fx:id="txtFieldID" prefHeight="27.0" prefWidth="55.0" styleClass="date-picker" />
                  <Label fx:id="lblCantidad" styleClass="Texto-remarcado-azul" text="Cantidad">
                     <padding>
                        <Insets top="5.0" />
                     </padding>
                  </Label>
                  <TextField fx:id="txtFieldCantidad" minHeight="0.0" minWidth="40.0" prefWidth="80.0" styleClass="date-picker" />
                  <Button fx:id="btnMas1" alignment="CENTER" mnemonicParsing="false" prefHeight="47.0" prefWidth="298.0" styleClass="Boton-Azul" text="Añadir">
                     <HBox.margin>
                        <Insets left="10.0" right="20.0" />
                     </HBox.margin>
                  </Button>
               </children>
               <padding>
                  <Insets bottom="15.0" left="15.0" top="15.0" />
               </padding>
            </HBox>
            <Label fx:id="lblLista" styleClass="Texto-remarcado-azul" text="Lista de productos">
               <padding>
                  <Insets bottom="5.0" left="140.0" />
               </padding>
            </Label>
         </children>
         <BorderPane.margin>
            <Insets left="20.0" />
         </BorderPane.margin>
      </VBox>
   </top>
   <center>
      <TableView fx:id="tablevTabla" prefHeight="393.0" prefWidth="587.0" styleClass="list-cell" BorderPane.alignment="CENTER">
         <columns>
            <TableColumn fx:id="tcId" prefWidth="150.0" text="SKU" />
            <TableColumn fx:id="tcDescripcion" prefWidth="100.0" text="Descripción" />
            <TableColumn fx:id="tcCantidad" prefWidth="100.0" text="Cantidad" />
         </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
         <opaqueInsets>
            <Insets />
         </opaqueInsets>
         <BorderPane.margin>
            <Insets bottom="20.0" left="20.0" right="20.0" />
         </BorderPane.margin>
      </TableView>
   </center>
   <bottom>
      <HBox prefHeight="40.0" prefWidth="200.0" spacing="15.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets left="230.0" />
         </padding>
         <children>
            <Button fx:id="btnSave" mnemonicParsing="false" prefWidth="52.0" styleClass="Boton-Azul" text="GUARDAR" />
            <Button fx:id="btnBorrar" maxHeight="26.0" maxWidth="80.0" minHeight="0.0" minWidth="30.0" mnemonicParsing="false" onAction="#eliminarProducto" prefHeight="0.0" prefWidth="52.0" styleClass="Boton-Rojo" text="BORRAR" />
         </children>
         <BorderPane.margin>
            <Insets bottom="20.0" />
         </BorderPane.margin>
      </HBox>
   </bottom>
</BorderPane>
